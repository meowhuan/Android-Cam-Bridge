<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="18dp"
    android:background="#182235"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/appUpdateTitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/app_update_title"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/appUpdateSubtitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/app_update_subtitle"
        android:textColor="#94A3B8"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/appUpdateBannerText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="#2A5B3FD4"
        android:paddingLeft="12dp"
        android:paddingTop="10dp"
        android:paddingRight="12dp"
        android:paddingBottom="10dp"
        android:textColor="#F8FAFC"
        android:textSize="13sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/appUpdateCurrentVersionText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="#E2E8F0"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/appUpdateLatestVersionText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="#E2E8F0"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/appUpdateLastCheckedText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="#94A3B8"
        android:textSize="12sp" />

    <CheckBox
        android:id="@+id/appUpdatePreviewCheckbox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/app_update_preview_opt_in"
        android:textColor="#FFFFFF" />

    <CheckBox
        android:id="@+id/appUpdateSuppressRemindersCheckbox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/app_update_suppress_reminders"
        android:textColor="#FFFFFF" />

    <TextView
        android:id="@+id/appUpdateSuppressRemindersHintText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="@string/app_update_suppress_hint"
        android:textColor="#94A3B8"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/appUpdateRiskText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="#141E2E"
        android:paddingLeft="12dp"
        android:paddingTop="10dp"
        android:paddingRight="12dp"
        android:paddingBottom="10dp"
        android:text="@string/app_update_preview_risk"
        android:textColor="#F8FAFC"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/appUpdateStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/app_update_status_default"
        android:textColor="#C7D2FE"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/appUpdateCheckButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:backgroundTint="#5B3FD4"
            android:text="@string/btn_check_updates"
            android:textAllCaps="false"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/appUpdateOpenReleasesButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:backgroundTint="#394155"
            android:text="@string/btn_open_releases"
            android:textAllCaps="false"
            android:textColor="#FFFFFF" />
    </LinearLayout>
</LinearLayout>
