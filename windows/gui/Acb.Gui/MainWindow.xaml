<Window
    x:Class="Acb.Gui.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="ACB Receiver">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Padding="20" Spacing="10">
            <TextBlock x:Name="AppTitleText" Text="ACB Receiver" FontSize="26" FontWeight="SemiBold" />
            <TextBlock x:Name="ConnectionTitleText" Text="Connection" FontSize="16" Opacity="0.8" />
            <ComboBox x:Name="LanguageBox" SelectionChanged="OnLanguageChanged" SelectedIndex="0">
                <ComboBoxItem Tag="auto" Content="Auto" />
                <ComboBoxItem Tag="zh-CN" Content="简体中文" />
                <ComboBoxItem Tag="en-US" Content="English" />
            </ComboBox>
            <TextBox x:Name="ReceiverAddressBox" Text="http://127.0.0.1:39393" PlaceholderText="receiver address" />
            <ComboBox x:Name="ConnectionModeBox" SelectedIndex="0">
                <ComboBoxItem x:Name="ConnectionModeManagedItem" Tag="managed" Content="managed" />
                <ComboBoxItem x:Name="ConnectionModeAttachItem" Tag="attach" Content="attach" />
            </ComboBox>
            <Button x:Name="SetupAdbButton" Content="Setup ADB" Click="OnSetupAdb" />
            <Button x:Name="RefreshDevicesButton" Content="Refresh Devices" Click="OnRefreshDevices" />
            <ComboBox x:Name="TransportBox" SelectedIndex="0">
                <ComboBoxItem x:Name="TransportUsbItem" Tag="usb-adb" Content="usb-adb" />
                <ComboBoxItem x:Name="TransportLanItem" Tag="lan" Content="lan" />
            </ComboBox>
            <ComboBox x:Name="QualityPresetBox" SelectedIndex="0">
                <ComboBoxItem x:Name="QualityBalancedItem" Tag="balanced" Content="balanced" />
                <ComboBoxItem x:Name="QualityHighItem" Tag="high" Content="high" />
                <ComboBoxItem x:Name="QualityUltraItem" Tag="ultra" Content="ultra" />
            </ComboBox>
            <ComboBox x:Name="FitModeBox" SelectedIndex="0">
                <ComboBoxItem x:Name="FitLetterboxItem" Tag="letterbox" Content="letterbox" />
                <ComboBoxItem x:Name="FitCropItem" Tag="crop" Content="crop" />
                <ComboBoxItem x:Name="FitStretchItem" Tag="stretch" Content="stretch" />
            </ComboBox>
            <ComboBox x:Name="ResolutionBox" SelectedIndex="1">
                <ComboBoxItem Content="640x480" />
                <ComboBoxItem Content="1280x720" />
                <ComboBoxItem Content="1920x1080" />
            </ComboBox>
            <ComboBox x:Name="FpsBox" SelectedIndex="1">
                <ComboBoxItem Content="24" />
                <ComboBoxItem Content="30" />
                <ComboBoxItem Content="60" />
            </ComboBox>
            <TextBox x:Name="BitrateBox" Text="4000000" PlaceholderText="video bitrate bps" />
            <CheckBox x:Name="AudioEnabledBox" IsChecked="True" Content="Audio Enabled" />
            <CheckBox x:Name="AutoStopReceiverBox" IsChecked="True" Content="Stop managed receiver on exit" />
            <Button x:Name="StartSessionButton" Content="Start v2 Session" Click="OnStartSession" />
            <Button x:Name="StopSessionButton" Content="Stop v2 Session" Click="OnStopSession" />
            <TextBox x:Name="SessionIdBox" PlaceholderText="session id" />
            <Button x:Name="FetchStatsButton" Content="Fetch v2 Stats" Click="OnFetchStats" />
            <Button x:Name="AutoRefreshButton" Content="Auto Refresh Stats (5s)" Click="OnToggleAutoRefreshStats" />
        </StackPanel>

        <StackPanel Grid.Column="1" Padding="20" Spacing="10">
            <TextBlock x:Name="OutputTitleText" Text="Output" FontSize="16" Opacity="0.8" />
            <TextBox x:Name="OutputBox" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True" MinHeight="520" />
        </StackPanel>
    </Grid>
</Window>
